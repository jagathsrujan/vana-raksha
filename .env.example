# .env Example
# Copy this file to .env (no quotes around values)

# OpenAI API Key (get at https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# OR if using Cloudflare Worker proxy (recommended — key never reaches browser):
# VITE_API_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# Default model (must be OpenAI-compatible chat model with vision)
VITE_MODEL=gpt-4o