# .env Example
# Copy this file to .env (no quotes around values)

# OpenCode Zen API Key (get at https://opencode.ai/auth)
VITE_ZEN_API_KEY=your-opencode-zen-api-key-here

# OR if using Cloudflare Worker proxy (recommended — key never reaches browser):
# VITE_API_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# Default model (OpenCode Zen model ID — must support vision)
VITE_MODEL=gpt-5.4-mini
